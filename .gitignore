*.tsbuildinfo

# Vite
*.local

# Test coverage
coverage/

# Tauri (Rust backend)
# Compiled files and executables are in src-tauri/.gitignore
# but we include key patterns here for visibility

# Rust target directory (compiled output)
src-tauri/target/

# Generated Tauri schema files
src-tauri/gen/

# Sidecar binaries (platform-specific, generated by prepare-sidecar.sh)
src-tauri/binaries/

# Cargo lock is typically committed for applications
# !src-tauri/Cargo.lock

