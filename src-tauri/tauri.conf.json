{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grove",
  "version": "0.1.0",
  "identifier": "com.grove.worktrees",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Grove",
        "width": 1440,
        "height": 900,
        "center": true,
        "visible": false,
        "resizable": true,
        "minWidth": 900,
        "minHeight": 650,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/grove"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ4M0RGNjFCMkU5OTY0RDAKUldUUVpKa3VHL1k5MkRHUUpjQkJod0JLMDZmMGNORWZiUENna2txTk9lbEZSc1NWQXY3NENMSnAK",
      "endpoints": [
        "https://grove-updates.stuntrocket.dev/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
